{
  "name": "mono",
  "private": true,
  "workspaces": [
    "analytics-service",
    "audit-service",
    "auth-service",
    "notification-service",
    "url-service",
    "shared",
    "web-ui"
  ],
  "scripts": {
    "bootstrap": "lerna bootstrap",
    "start": "lerna run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lerna": "^8.1.8",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "amqplib": "0.10.4",
    "cors": "^2.8.5",
    "dotenv": "16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.14",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "winston": "^3.14.1"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx,css,json,yaml,yml,md}": "prettier --write"
  }
}
