{
  "root": true,
  "env": { "node": true, "es2022": true },
  "parserOptions": { "ecmaVersion": 2022 },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "eqeqeq": ["error", "always"],
    "no-var": "error",
    "prefer-const": "warn",
    "no-console": "warn"
  },
  "ignorePatterns": [
    "node_modules/",
    "coverage/",
    "dist/",
    ".next/",
    "prisma/",
    "**/*.config.ts",
    "**/*.test.js",
    "**/test/**",
    "**/tests/**",
    "vitest.workspace.ts"
  ]
}
